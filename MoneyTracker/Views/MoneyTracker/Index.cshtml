@{
    ViewData["Title"] = "Expenses";
}

<div class="text-center">
    <h1 class="display-4">Expenses</h1>
    <br />
    <table class="table" id="expensesTable">
        <thead>
            <tr>
                <th>Id</th>
                <th>Value</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="expensesBody">
            <!-- Data will be injected here -->
        </tbody>
    </table>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            Swal.fire({
                title: 'Loading expenses...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/api/MoneyTracker/expenses',
                method: 'GET',
                success: function (data) {
                    Swal.close(); // Close loading alert

                    let rows = '';
                    data.forEach(function (expense) {
                        rows += `
                            <tr>
                                <td>${expense.id}</td>
                                <td>${expense.value}</td>
                                <td>${expense.description}</td>
                                <td>
                                    <a href="/MoneyTracker/CreateEditExpense/${expense.id}">Edit</a>
                                    <a href="/MoneyTracker/DeleteExpense/${expense.id}">Delete</a>
                                </td>
                            </tr>
                        `;
                    });
                    $('#expensesBody').html(rows);
                },
                error: function () {
                    Swal.close(); // Close loading alert
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: 'Failed to load expenses!',
                        confirmButtonColor: '#d33'
                    });
                }
            });
        });

    </script>
}
